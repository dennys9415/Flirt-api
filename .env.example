# --- Server ---
PORT=3000

# --- Database (matches docker-compose defaults) ---
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=flirt
DATABASE_PASSWORD=flirt_dev_password
DATABASE_NAME=flirt

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# --- AI provider layer (config-driven, swappable) ---
# Provider: fake | openai | anthropic | gemini
# "fake" returns deterministic suggestions — no API key needed (local dev/tests)
AI_PROVIDER=fake
AI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Subscriptions (v0.4) ---
# trust_client: accept StoreKit-testing claims (local dev — real verification
# via App Store Server API lands with the Apple Developer account at v1.0)
SUBSCRIPTION_VERIFY_MODE=trust_client

# --- Limits (designed, NOT enforced during MVP — see COST_MODEL.md) ---
# Plan limit enforcement stays OFF for the powerful-MVP phase.
ENFORCE_PLAN_LIMITS=false
FREE_PLAN_DAILY_LIMIT=20
# Anti-abuse ceiling only: absurdly high for a human, low for a bot.
ABUSE_MAX_REQUESTS_PER_HOUR=100

# --- BYOK (v0.5) ---
# 64 hex chars (openssl rand -hex 32) — encrypts user AI keys at rest.
# Rotating it invalidates stored user keys (they fall back to the system provider).
API_KEY_ENCRYPTION_SECRET=
